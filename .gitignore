# R package
.Rproj.user/
.Rhistory
.RData
.Ruserdata
*.Rproj

# Proprietary / large guideline data files (not bundled per HANDOVER.md §2.1)
guideline data/

# Test database (local copy only — contains monitoring data)
test data/

# Pipeline helper and exploratory scripts (not package code)
scripts/

# Reference papers / PDFs (copyright; local reading copies only)
references/

# R build artefacts
/doc/
/Meta/

# pkgdown site (built and deployed to the gh-pages branch by GitHub Actions)
docs/

# README render preview (generated from README.Rmd)
/README.html

# Pre-built vignette HTML (generated artefacts)
vignettes/*.html

# R CMD check output dir + built tarballs (never tracked)
*.Rcheck/
*.tar.gz
.claude/

# Exploratory / scratch — never tracked
dev/
